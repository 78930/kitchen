# ─────────────────────────────────────────────────────────────
# The Madhu's Kitchen — Environment Variables
# Copy to .env (local) or add in Vercel → Project → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────

# MongoDB (Atlas connection string)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/sa_caterers?retryWrites=true&w=majority

# ── Email engine (Nodemailer over SMTP / Gmail) ──
# For Gmail: enable 2FA, then create an App Password (https://myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your.gmail.address@gmail.com
SMTP_PASS=your_16_char_app_password
MAIL_FROM="The Madhu's Kitchen <your.gmail.address@gmail.com>"
ADMIN_EMAIL=sa.hyderabadcaterers@gmail.com

# ── WhatsApp alerts (CallMeBot — free) ──
# 1. Save +916303644615 in your WhatsApp contacts as "CallMeBot"
# 2. Send "I allow callmebot to send me messages" to +34 644 59 78 99 on WhatsApp
# 3. Paste the API key you receive in reply below.
WHATSAPP_NOTIFY_PHONE=+916303644615
CALLMEBOT_APIKEY=your_callmebot_api_key

# ── Admin dashboard auth ──
# A shared admin password (used to issue a JWT) and a JWT signing secret.
ADMIN_PASSWORD=change-this-strong-password
JWT_SECRET=replace-with-a-long-random-string

# Optional: comma-separated allowed origins for CORS (leave blank to allow same-origin)
CORS_ORIGINS=
